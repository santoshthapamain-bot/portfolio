<div class="contact-grid">
  <div class="reveal">
    <p style="color:var(--text-muted);margin-bottom:8px;">Reach out directly or drop a message — I read every one.</p>

    <div class="contact-info-list">
      <% if (contact && contact.email) { %>
      <a class="contact-info-item glass" href="mailto:<%= contact.email %>">
        <span class="ic">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16v16H4z"/><path d="M22 6l-10 7L2 6"/></svg>
        </span>
        <div><span>Email</span><strong><%= contact.email %></strong></div>
      </a>
      <% } %>
      <% if (contact && contact.phone) { %>
      <a class="contact-info-item glass" href="tel:<%= contact.phone %>">
        <span class="ic">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        </span>
        <div><span>Phone</span><strong><%= contact.phone %></strong></div>
      </a>
      <% } %>
      <% if (contact && contact.address) { %>
      <div class="contact-info-item glass">
        <span class="ic">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </span>
        <div><span>Location</span><strong><%= contact.address %></strong></div>
      </div>
      <% } %>
    </div>

    <% if (social && social.length) { %>
    <div class="social-row">
      <% social.forEach(function(s){ %>
        <a class="social-btn" href="<%= s.url %>" target="_blank" rel="noopener" title="<%= s.platform %>">
          <% if (s.icon) { %><%- s.icon %><% } else { %><span style="font-size:11px;font-family:var(--font-mono)"><%= s.platform.slice(0,2).toUpperCase() %></span><% } %>
        </a>
      <% }); %>
    </div>
    <% } %>
  </div>

  <div class="glass reveal" style="padding:32px;">
    <% if (typeof sent !== 'undefined' && sent) { %>
      <div class="alert alert-success">Thanks! Your message has been sent — I'll get back to you soon.</div>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>
    <form method="POST" action="/contact">
      <div class="form-row">
        <div class="form-group">
          <label for="name">Your name</label>
          <input class="form-control" type="text" id="name" name="name" placeholder="Jane Doe" required>
        </div>
        <div class="form-group">
          <label for="email">Your email</label>
          <input class="form-control" type="email" id="email" name="email" placeholder="jane@example.com" required>
        </div>
      </div>
      <div class="form-group">
        <label for="subject">Subject</label>
        <input class="form-control" type="text" id="subject" name="subject" placeholder="Let's work together">
      </div>
      <div class="form-group">
        <label for="message">Message</label>
        <textarea class="form-control" id="message" name="message" placeholder="Tell me a bit about your project..." required></textarea>
      </div>
      <button type="submit" class="btn btn-primary btn-block">Send message</button>
    </form>
  </div>
</div>
